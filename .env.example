# Vespera Environment Variables
# Copy this file to .env and fill in your values

# Local model (Ollama)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen2.5:7b

# Cloud model (only used when local hands off)
CLOUD_PROVIDER=claude
CLOUD_MODEL=claude-sonnet-4-5
CLOUD_API_KEY=your_api_key_here

# Web search (Venice AI — free tier)
VENICE_API_KEY=your_venice_key_here

# Timing (seconds)
BACKGROUND_LOOP_INTERVAL=180
CLEANUP_INTERVAL=300
PRUNING_INTERVAL_DAYS=3

# Tuning
COMPLEXITY_THRESHOLD=0.65
MAX_THOUGHT_LENGTH=300
