# Vespera Environment Variables
# Copy this to .env and fill in your values

# ── Background Loop (persistent thinker) ──────────────────
BACKGROUND_OLLAMA_MODEL=llama3.2:3b
BACKGROUND_OLLAMA_URL=http://localhost:11434/api/generate
BACKGROUND_API_KEY=

# ── Cleanup Crew (frequent light review) ──────────────────
CLEANUP_OLLAMA_MODEL=llama3.2:3b
CLEANUP_OLLAMA_URL=http://localhost:11434/api/generate
CLEANUP_API_KEY=

# ── Periodic Pruning (deep review every 3 days) ───────────
PRUNING_OLLAMA_MODEL=llama3.2:3b
PRUNING_OLLAMA_URL=http://localhost:11434/api/generate
PRUNING_API_KEY=

# ── Handoff Logic (complexity scorer) ─────────────────────
HANDOFF_OLLAMA_MODEL=llama3.2:3b
HANDOFF_OLLAMA_URL=http://localhost:11434/api/generate
HANDOFF_API_KEY=

# ── Cloud Model (called when local hands off) ──────────────
CLOUD_PROVIDER=claude
CLOUD_MODEL=claude-sonnet-4-5
CLOUD_API_KEY=your_key_here
CLOUD_BASE_URL=

# ── Web Search (Venice AI — free tier) ────────────────────
VENICE_API_KEY=your_key_here

# ── Timing ────────────────────────────────────────────────
BACKGROUND_LOOP_INTERVAL=180
CLEANUP_INTERVAL=300
PRUNING_INTERVAL_DAYS=3

# ── Tuning ────────────────────────────────────────────────
COMPLEXITY_THRESHOLD=0.65
MAX_THOUGHT_LENGTH=300
CLEANUP_BATCH_SIZE=5
PRUNING_BATCH_SIZE=20
