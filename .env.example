# ─────────────────────────────────────────────
# Vespera Configuration
# Copy this file to .env and fill in your values.
# Everything marked OPTIONAL works without a key.
# ─────────────────────────────────────────────

# ── CLOUD AI (Optional but recommended) ──────
# Without this, Vespera uses the local model for everything.
# Supported providers: claude, groq, openai, gemini, venice
#
# Groq (free tier, fast): https://console.groq.com
# Google Gemini (free tier): https://aistudio.google.com
# Anthropic Claude: https://console.anthropic.com
# OpenAI: https://platform.openai.com
# Venice AI: https://venice.ai
CLOUD_API_KEY=
CLOUD_PROVIDER=groq
CLOUD_MODEL=llama3-8b-8192

# ── LOCAL MODEL ───────────────────────────────
# Ollama must be installed and running.
# Download a model first: ollama pull qwen2.5:14b
# All components default to this model.
# qwen2.5:14b is recommended — best quality that fits in 16GB RAM
# Download: ollama pull qwen2.5:14b
# Lighter option (faster, less RAM): mistral:7b
BACKGROUND_OLLAMA_MODEL=qwen2.5:14b
CLEANUP_OLLAMA_MODEL=qwen2.5:14b
HANDOFF_OLLAMA_MODEL=qwen2.5:14b
PRUNING_OLLAMA_MODEL=qwen2.5:14b

# ── TELEGRAM BOT (Optional) ──────────────────
# Get a free bot token from @BotFather on Telegram.
# TELEGRAM_ALLOWED_USERS: comma-separated Telegram user IDs.
# Get your ID by messaging @userinfobot on Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# ── WEB SEARCH (Optional) ────────────────────
# DuckDuckGo works with no key. For better results:
# Brave Search free API key: https://brave.com/search/api/
BRAVE_API_KEY=

# ── VOICE / TTS (Optional) ───────────────────
# Venice AI key for high-quality voice.
# Without it, falls back to edge-tts (free) then kokoro-onnx (local).
VENICE_API_KEY=
TTS_VOICE=am_michael          # Venice AI voice name (only used if VENICE_API_KEY is set)
EDGE_TTS_VOICE=en-US-GuyNeural

# ── SECURITY ──────────────────────────────────
# Allow Vespera to run shell commands on your machine.
# ⚠️  WARNING: Enabling this gives the AI the ability to run commands on your computer.
# Only enable this if you understand the risks.
VESPERA_ALLOW_SHELL=false

# Restrict file access to these directories (comma-separated).
# Default is a safe dedicated folder. Change with caution.
VESPERA_ALLOW_PATHS=~/.vespera/workspace

# Require this token on all API requests (leave blank = no auth required).
# Recommended if you expose the API beyond localhost.
VESPERA_API_TOKEN=

# Max tokens per cloud model response (cost control).
VESPERA_MAX_TOKENS=1024

# ── TIMEZONE ──────────────────────────────────
# Used for reminders and scheduling.
# Find yours at: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
VESPERA_TIMEZONE=America/Chicago

# ── API SERVER ────────────────────────────────
# If port 5055 is already in use on your machine, Vespera will
# automatically try 5056, 5057, etc. and tell you which one it picked.
# Set this to lock in a specific port.
VESPERA_API_URL=http://localhost:5055
API_PORT=5055

# UI port (Vespera web interface)
# If 3055 is taken, change this and restart the UI.
UI_PORT=3055
